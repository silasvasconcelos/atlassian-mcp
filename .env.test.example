# Copy to .env.test and fill with real values

# Basic auth (optional)
JIRA_TEST_BASIC_BASE_URL=https://<site>.atlassian.net
JIRA_TEST_BASIC_EMAIL=user@example.com
JIRA_TEST_BASIC_API_TOKEN=token_here

# OAuth 2.0 (3LO) auth (optional)
JIRA_TEST_OAUTH_ACCESS_TOKEN=access_token_here
JIRA_TEST_OAUTH_CLOUD_ID=cloud_id_here

# Issue to read (required for issue test)
JIRA_TEST_ISSUE_KEY=ABC-123
# Which auth to use for issue test: basic or oauth2
JIRA_TEST_ISSUE_AUTH_MODE=basic
