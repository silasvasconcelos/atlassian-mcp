{
  "openapi": "3.0.0",
  "info": {
    "title": "Jira Mock",
    "version": "1.0.0"
  },
  "paths": {
    "/rest/api/3/issue/{issueIdOrKey}": {
      "get": {
        "operationId": "getIssue",
        "summary": "Get issue",
        "parameters": [
          {"name": "issueIdOrKey", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "expand", "in": "query", "required": false, "schema": {"type": "string"}},
          {"name": "X-Atlassian-Token", "in": "header", "required": false, "schema": {"type": "string"}}
        ]
      }
    },
    "/rest/api/3/issue": {
      "post": {
        "operationId": "createIssue",
        "summary": "Create issue",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fields": {"type": "object"}
                },
                "required": ["fields"]
              }
            }
          }
        }
      }
    }
  }
}
